{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "redirects": [
    { "source": "/menu", "destination": "/menu.html", "permanent": true },
    { "source": "/menus", "destination": "/menu.html", "permanent": true },
    { "source": "/food", "destination": "/menu.html", "permanent": true },
    { "source": "/about", "destination": "/about.html", "permanent": true },
    { "source": "/about-us", "destination": "/about.html", "permanent": true },
    { "source": "/aboutus", "destination": "/about.html", "permanent": true },
    { "source": "/our-story", "destination": "/about.html", "permanent": true },
    { "source": "/story", "destination": "/about.html", "permanent": true },
    { "source": "/gallery", "destination": "/gallery.html", "permanent": true },
    { "source": "/photos", "destination": "/gallery.html", "permanent": true },
    { "source": "/photo-gallery", "destination": "/gallery.html", "permanent": true },
    { "source": "/reservations", "destination": "/visit.html", "permanent": true },
    { "source": "/reservation", "destination": "/visit.html", "permanent": true },
    { "source": "/reserve", "destination": "/visit.html", "permanent": true },
    { "source": "/book", "destination": "/visit.html", "permanent": true },
    { "source": "/booking", "destination": "/visit.html", "permanent": true },
    { "source": "/find-us", "destination": "/visit.html", "permanent": true },
    { "source": "/findus", "destination": "/visit.html", "permanent": true },
    { "source": "/contact", "destination": "/visit.html", "permanent": true },
    { "source": "/contact-us", "destination": "/visit.html", "permanent": true },
    { "source": "/location", "destination": "/visit.html", "permanent": true },
    { "source": "/visit", "destination": "/visit.html", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true }
  ],
  "headers": [
    { "source": "/(.*)\\.(avif|webp|jpg|jpeg|png|gif|svg|ico|mp4|woff2|woff|otf|ttf)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/(.*)\\.(css|js)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }] },
    { "source": "/(.*)\\.html", "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] }
  ]
}
